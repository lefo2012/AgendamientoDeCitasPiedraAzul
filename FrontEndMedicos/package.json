{
  "name": "front-end-medicos",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "prestart": "node scripts/load-env.js",
    "build": "ng build",
    "prebuild": "node scripts/load-env.js",
    "watch": "ng build --watch --configuration development",
    "prewatch": "node scripts/load-env.js",
    "test": "ng test",
    "pretest": "node scripts/load-env.js",
    "serve:ssr:FrontEndMedicos": "node dist/FrontEndMedicos/server/server.mjs"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
